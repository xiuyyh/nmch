
{
  "entities": {
    "StockItem": {
      "title": "Bar Stock Item",
      "description": "An item in the bar's inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "min": { "type": "number" },
        "price": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "stock", "min", "price"]
    },
    "WarehouseItem": {
      "title": "Warehouse Stock Item",
      "description": "An item in the main store/warehouse",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "min": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "stock", "min"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "A vendor that provides stock",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["name"]
    },
    "StockReceival": {
      "title": "Stock Receival",
      "description": "A record of items received from a supplier into the warehouse",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "receivedDate": { "type": "string", "format": "date-time" },
        "receivedBy": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        }
      },
      "required": ["supplierId", "receivedDate", "items", "receivedBy"]
    },
    "InventoryCategory": {
      "title": "Inventory Category",
      "description": "A category for grouping inventory items",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Sale": {
      "title": "Sale Record",
      "description": "A recorded transaction",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "method": { "type": "string", "enum": ["Card", "Cash", "Transfer"] },
        "tableNumber": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Completed", "Canceled"] },
        "canceledAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "total", "method", "timestamp"]
    },
    "TableSession": {
      "title": "Active Table Session",
      "description": "An ongoing order for a specific table",
      "type": "object",
      "properties": {
        "tableNumber": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["tableNumber", "items"]
    },
    "DailyClosing": {
      "title": "Daily Settlement Record",
      "description": "Marker for a day that has been settled and locked",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "settledAt": { "type": "string", "format": "date-time" },
        "settledBy": { "type": "string" },
        "totalRevenue": { "type": "number" }
      },
      "required": ["date", "settledAt"]
    },
    "RestockRequest": {
      "title": "Restock Request",
      "description": "A request for more stock from the bar to the store",
      "type": "object",
      "properties": {
        "requestDate": { "type": "string", "format": "date-time" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "requestedQuantity": { "type": "number" }
            }
          }
        },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "requestedBy": { "type": "string" },
        "processedBy": { "type": "string" },
        "processedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requestDate", "items", "status", "requestedBy"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/inventory/{itemId}": {
      "schema": "StockItem",
      "description": "Collection of bar inventory items"
    },
    "/warehouseInventory/{itemId}": {
      "schema": "WarehouseItem",
      "description": "Collection of main warehouse inventory items"
    },
    "/warehouseCategories/{categoryId}": {
      "schema": "InventoryCategory",
      "description": "Categories for warehouse inventory"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "List of vendors/suppliers"
    },
    "/stockReceivals/{receivalId}": {
      "schema": "StockReceival",
      "description": "History of stock received from suppliers"
    },
    "/inventoryCategories/{categoryId}": {
      "schema": "InventoryCategory",
      "description": "Managed categories for bar inventory"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "History of sales"
    },
    "/tableSessions/{tableNumber}": {
      "schema": "TableSession",
      "description": "Active tabs for tables"
    },
    "/dailyClosings/{dateString}": {
      "schema": "DailyClosing",
      "description": "Settlement records per day (format YYYY-MM-DD)"
    },
    "/restockRequests/{requestId}": {
      "schema": "RestockRequest",
      "description": "Collection of restock requests"
    }
  }
}
