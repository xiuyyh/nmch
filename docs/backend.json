
{
  "entities": {
    "UserRecord": {
      "title": "User Profile",
      "description": "User role and profile data stored in Firestore",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { 
          "type": "string", 
          "enum": ["admin", "bar", "kitchen", "store", "front_desk", "housekeeper"] 
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "StockItem": {
      "title": "Bar Stock Item",
      "description": "An item in the bar's inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "min": { "type": "number" },
        "price": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "stock", "min", "price"]
    },
    "WarehouseItem": {
      "title": "Warehouse Stock Item",
      "description": "An item in the main store/warehouse",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "min": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "stock", "min"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "A vendor that provides stock",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["name"]
    },
    "StockReceival": {
      "title": "Stock Receival",
      "description": "A record of items received from a supplier into the warehouse",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "receivedDate": { "type": "string", "format": "date-time" },
        "receivedBy": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        }
      },
      "required": ["supplierId", "receivedDate", "items", "receivedBy"]
    },
    "InventoryCategory": {
      "title": "Inventory Category",
      "description": "A category for grouping inventory items",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Sale": {
      "title": "Sale Record",
      "description": "A recorded transaction",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "method": { "type": "string", "enum": ["Card", "Cash", "Transfer", "Unsettled"] },
        "tableNumber": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Completed", "Canceled", "Unsettled"] },
        "canceledAt": { "type": "string", "format": "date-time" },
        "staffName": { "type": "string" },
        "shiftId": { "type": "string" }
      },
      "required": ["items", "total", "method", "timestamp"]
    },
    "TableSession": {
      "title": "Active Table Session",
      "description": "An ongoing order for a specific table",
      "type": "object",
      "properties": {
        "tableNumber": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "lastSentQuantity": { "type": "number" }
            }
          }
        },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["tableNumber", "items"]
    },
    "RestockRequest": {
      "title": "Restock Request",
      "description": "A request for more stock from the bar to the store",
      "type": "object",
      "properties": {
        "requestDate": { "type": "string", "format": "date-time" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "requestedQuantity": { "type": "number" }
            }
          }
        },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "requestedBy": { "type": "string" },
        "processedBy": { "type": "string" },
        "processedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requestDate", "items", "status", "requestedBy"]
    },
    "KitchenOrder": {
      "title": "Kitchen Order",
      "description": "An order sent to the kitchen",
      "type": "object",
      "properties": {
        "tableNumber": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" },
        "staffName": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Delivered"] },
        "deliveredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tableNumber", "items", "timestamp"]
    },
    "Shift": {
      "title": "Shift Record",
      "description": "Record of a staff member's shift including opening stock",
      "type": "object",
      "properties": {
        "staffId": { "type": "string" },
        "staffName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "openingStock": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "status": { "type": "string", "enum": ["active", "closed"] }
      },
      "required": ["staffId", "staffName", "startTime", "openingStock", "status"]
    },
    "AdminAction": {
      "title": "Admin Action Log",
      "description": "History of sensitive actions performed by administrators",
      "type": "object",
      "properties": {
        "adminName": { "type": "string" },
        "adminId": { "type": "string" },
        "action": { "type": "string" },
        "entity": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["adminName", "action", "timestamp"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserRecord",
      "description": "User metadata and permissions"
    },
    "/inventory/{itemId}": {
      "schema": "StockItem",
      "description": "Collection of bar inventory items"
    },
    "/warehouseInventory/{itemId}": {
      "schema": "WarehouseItem",
      "description": "Collection of main warehouse inventory items"
    },
    "/warehouseCategories/{categoryId}": {
      "schema": "InventoryCategory",
      "description": "Categories for warehouse inventory"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "List of vendors/suppliers"
    },
    "/stockReceivals/{receivalId}": {
      "schema": "StockReceival",
      "description": "History of stock received from suppliers"
    },
    "/inventoryCategories/{categoryId}": {
      "schema": "InventoryCategory",
      "description": "Managed categories for bar inventory"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "History of sales"
    },
    "/tableSessions/{tableNumber}": {
      "schema": "TableSession",
      "description": "Active tabs for tables"
    },
    "/restockRequests/{requestId}": {
      "schema": "RestockRequest",
      "description": "Collection of restock requests"
    },
    "/kitchenOrders/{orderId}": {
      "schema": "KitchenOrder",
      "description": "Orders currently being processed by the kitchen"
    },
    "/shifts/{shiftId}": {
      "schema": "Shift",
      "description": "History of staff shifts and opening stock"
    },
    "/adminActions/{actionId}": {
      "schema": "AdminAction",
      "description": "Audit trail of admin operations"
    }
  }
}
