
{
  "entities": {
    "StockItem": {
      "title": "Stock Item",
      "description": "An item in the bar's inventory",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "unit": { "type": "string" },
        "min": { "type": "number" },
        "price": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "stock", "min", "price"]
    },
    "Sale": {
      "title": "Sale Record",
      "description": "A recorded transaction",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "method": { "type": "string", "enum": ["Card", "Cash"] },
        "tableNumber": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "total", "method", "timestamp"]
    },
    "TableSession": {
      "title": "Active Table Session",
      "description": "An ongoing order for a specific table",
      "type": "object",
      "properties": {
        "tableNumber": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "itemId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["tableNumber", "items"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/inventory/{itemId}": {
      "schema": "StockItem",
      "description": "Collection of inventory items"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "History of sales"
    },
    "/tableSessions/{tableNumber}": {
      "schema": "TableSession",
      "description": "Active tabs for tables"
    }
  }
}
